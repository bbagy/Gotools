get_script_path <- function() {
cmd_args <- commandArgs(trailingOnly = FALSE)
file_arg <- grep("^--file=", cmd_args, value = TRUE)
if (length(file_arg) > 0) {
return(dirname(normalizePath(sub("^--file=", "", file_arg[1]), winslash = "/", mustWork = TRUE)))
}
if (!is.null(sys.frames()[[1]]$ofile)) {
return(dirname(normalizePath(sys.frames()[[1]]$ofile, winslash = "/", mustWork = TRUE)))
}
normalizePath(getwd(), winslash = "/", mustWork = TRUE)
}
find_analysis_dir <- function() {
candidate_dirs <- c(
get_script_path(),
getwd(),
file.path(getwd(), "20260323_reanalysis"),
dirname(getwd())
)
candidate_dirs <- unique(candidate_dirs[dir.exists(candidate_dirs)])
required_relpaths <- c(
"2_rds/ps.Yin_SV_fastq_20220107.230315.rds",
"1_out/Yin_SV_fastq_20220107.230315.seqs.fna_tree/exported-tree/tree.nwk",
"3_map/Mapdata_used_for_saliva_bacterial_infections_considering_timing.csv",
"2_rds/20240612_ps.Yin_CPIC_Merck_901_ST.rds",
"1_out/Yin_CPIC_all.240205.psTotab.seqs.fna_tree/exported-tree/tree.nwk",
"3_map/Mapdata_used_for_stool_bacterial_infections_considering_timing.csv"
)
for (candidate_dir in candidate_dirs) {
if (all(file.exists(file.path(candidate_dir, required_relpaths)))) {
return(normalizePath(candidate_dir, winslash = "/", mustWork = TRUE))
}
}
stop(
sprintf(
"Could not locate analysis directory. Checked: %s",
paste(candidate_dirs, collapse = ", ")
)
)
}
