# subgroups <- c("neg_CIN1","pos_CIN1", "pos_CIN2+")  # 나중에 "pos_CIN1", "pos_CIN2+"도 추가 가능
n <- 50
ps2_50 <- prune_taxa(names(sort(taxa_sums(ps2_st), decreasing = TRUE)[1:n]), ps2_st);ps2_50
#-----------------------------------------#
