###########################################
project <- "MAPS_Dav_BMT_16S_GAB_labelmerge"
masterdir <- "/Users/heekukpark/Library/CloudStorage/OneDrive-SharedLibraries-ColumbiaUniversityIrvingMedicalCenter/Uhlemann Lab - Microbiome Core/1_Projects/MAPS_Dav_BMT"
currentwd <- file.path(masterdir, "2_Analysis", "20260324_16S_GLP_dada2")
rmd_template_path <- "/Users/heekukpark/Dropbox/04_scripts/R_source/Gotool_html/16S/CUMC Microbiome Core Summary 16S Report_V2.Rmd"
summary_report_dir <- file.path(masterdir, "3_Summary_report")
template_mapping_file <- "3_map/20260324.fastq.mapping.csv"
source_mapping_new <- "3_map/20260316_16S_GLP25.mapping.csv"
source_mapping_old <- "3_map/241021.fastq.mapping.csv"
mapping_file <- "3_map/20260324.fastq.mapping.GAB_labelmerge.csv"
raw_asv_file <- "1_out/fastq.260324.asvTable.csv"
track_file <- "1_out/fastq.260324.track.csv"
tree_file <- "1_out/fastq.260324.seqs.fna_tree/exported-tree/tree.nwk"
blast_db <- find_blast_db()
group_orders <- c("VB_D+7", "V_D+7", "GLPB_D+7", "GLP2_D+7", "VB_D+14", "V_D+14", "GLPB_D+14", "GLP2_D+14")
time_orders <- c("D+7", "D+14")
barchart_tax_ranks <- c("Phylum", "Family", "Genus")
distance_metrics <- c("bray", "unifrac", "wunifrac")
alpha_metrics <- c("Chao1", "Shannon")
plot.col <- c("#2166AC", "#74ADD1", "#990000", "#E31A1C", "#2166AC", "#74ADD1", "#990000", "#E31A1C")
da.col <- c("#74ADD1", "#E31A1C")
expinfo_kit_number <- 2
expinfo_pos_number <- 1
expinfo_prep_number <- 3
expinfo_spikein_number <- 2
setwd(currentwd)
if (!dir.exists(summary_report_dir)) dir.create(summary_report_dir, recursive = TRUE)
############################################################
#=================      Metadata Build      =================#
############################################################
mapping_full <- build_mapping_file(template_mapping_file, source_mapping_new, source_mapping_old, mapping_file)
sampledata <- subset(mapping_full, AnalysisUse == "Include")
rownames(sampledata) <- sampledata$SampleID
sampledata$GroupLabel <- factor(sampledata$GroupLabel, levels = group_orders)
sampledata$Timepoint <- factor(sampledata$Timepoint, levels = time_orders)
sampledata$TreatmentGroup <- factor(sampledata$TreatmentGroup, levels = c("Vehicle", "GLP-2"))
sampledata$TreatmentGroup2 <- factor(sampledata$TreatmentGroup2, levels = c("Baseline", "Sample"))
da_comparisons <- list(
Vehicle_D7 = c("VB_D+7", "V_D+7"),
Vehicle_D14 = c("VB_D+14", "V_D+14"),
GLP2_D7 = c("GLPB_D+7", "GLP2_D+7"),
GLP2_D14 = c("GLPB_D+14", "GLP2_D+14")
)
############################################################
#=================      Input Selection      =================#
############################################################
feature_file <- find_latest_final_asv(project)
input_gap_note <- NA_character_
if (is.na(feature_file) || !file.exists(feature_file)) {
if (!is.na(blast_db)) {
Go_blastASVs(project = project, asvsTable = raw_asv_file, blastDB = blast_db)
feature_file <- find_latest_final_asv(project)
} else {
feature_file <- raw_asv_file
input_gap_note <- "BLAST DB was not available locally, so the run used the current asvTable taxonomy columns instead of a new final_asvTable."
}
}
if (is.na(feature_file) || !file.exists(feature_file)) stop("No valid ASV input file was available for Go_tabTops().")
ps.csv <- Go_tabTops(csv = feature_file, project = project)
tree <- ape::read.tree(tree_file)
ps0 <- merge_phyloseq(ps.csv, sample_data(sampledata), phy_tree(tree))
############################################################
#=================      Filtering Run      =================#
############################################################
cutoff <- 7500
seq_from <- 397
seq_to <- 450
abundance_cutoff <- 0.00005
ps1.prune <- prune_samples(sample_sums(ps0) > cutoff, ps0)
p.rare <- Go_rare(ps1.prune, step = 1000, color = "GroupLabel", xlimit = 20000, label = NULL, se = FALSE) + ggplot2::theme(legend.position = "right")
rare_dir <- Go_path(project, pdf = "yes", table = "no", path = NULL)
ggplot2::ggsave(sprintf("%s/1_rarefaction.%s.%s.(Rarefaction).pdf", rare_dir$pdf, project, format(Sys.Date(), "%y%m%d")), plot = p.rare, device = "pdf", width = 8, height = 5, limitsize = FALSE)
Go_SeqLengths(ps1.prune)
ps1.size <- Go_SeqLengths(ps1.prune, from = seq_from, to = seq_to)
ps_filtered <- Go_filter(ps1.size, cutoff = abundance_cutoff)
meta0 <- data.frame(sample_data(ps_filtered), check.names = FALSE)
meta0$GroupLabel <- factor(as.character(meta0$GroupLabel), levels = group_orders)
meta0$Timepoint <- factor(as.character(meta0$Timepoint), levels = time_orders)
ps_use <- prune_samples(rownames(meta0), ps_filtered)
sample_data(ps_use) <- sample_data(meta0)
############################################################
#=================      Core Analysis      =================#
############################################################
###########################################
#=========      Barchart         =========#
###########################################
for (tax_rank in barchart_tax_ranks) {
Go_barchart(psIN = ps_use, cate.vars = "GroupLabel", project = project, taxanames = tax_rank, orders = group_orders, simple = FALSE, mycols = plot.col, relative = TRUE, y_axis = NULL, x_label = NULL, facet = "Timepoint", legend = "bottom", cutoff = 0.01, name = ensure_report_token(tax_rank), ncol = NULL, mark = NULL, height = 5, width = 10)
}
###########################################
#=========       Heatmap          =========#
###########################################
Go_pheatmap(psIN = ps_use, project = project, title = NULL, group1 = "GroupLabel", group2 = NULL, group3 = NULL, group4 = NULL, Ntax = 50, name = ensure_report_token("GroupLabel"), col_orders = group_orders, show_rownames = TRUE, show_colnames = FALSE, cutree_rows = NA, cutree_cols = NA, cluster_rows = TRUE, cluster_cols = TRUE, showPhylum = TRUE, width = 10)
###########################################
#=========    Alpha Diversity     =========#
###########################################
adiv_all <- Go_adiv(psIN = ps_use, project = project, alpha_metrics = alpha_metrics, name = ensure_report_token("AllSamples"))
Go_boxplot(df = adiv_all, cate.vars = "GroupLabel", project = project, outcomes = alpha_metrics, orders = group_orders, mycols = plot.col, combination = NULL, ylim = NULL, title = NULL, facet = "Timepoint", paired = NULL, name = ensure_report_token("GroupLabel"), ncol = NULL, addnumber = TRUE, statistics = TRUE, covariates = NULL, p_adjust = TRUE, cutoff = 0.1, min_height = 2, min_width = 2, plotCols = 2, plotRows = 1)
############################################################
#=================      Metadata Build      =================#
############################################################
mapping_full <- build_mapping_file(template_mapping_file, source_mapping_new, source_mapping_old, mapping_file)
sampledata <- subset(mapping_full, AnalysisUse == "Include")
rownames(sampledata) <- sampledata$SampleID
sampledata$GroupLabel <- factor(sampledata$GroupLabel, levels = group_orders)
sampledata$Timepoint <- factor(sampledata$Timepoint, levels = time_orders)
sampledata$TreatmentGroup <- factor(sampledata$TreatmentGroup, levels = c("Vehicle", "GLP-2"))
sampledata$TreatmentGroup2 <- factor(sampledata$TreatmentGroup2, levels = c("Baseline", "Sample"))
da_comparisons <- list(
Vehicle_D7 = c("VB_D+7", "V_D+7"),
Vehicle_D14 = c("VB_D+14", "V_D+14"),
GLP2_D7 = c("GLPB_D+7", "GLP2_D+7"),
GLP2_D14 = c("GLPB_D+14", "GLP2_D+14")
)
############################################################
#=================      Input Selection      =================#
############################################################
feature_file <- find_latest_final_asv(project)
input_gap_note <- NA_character_
if (is.na(feature_file) || !file.exists(feature_file)) {
if (!is.na(blast_db)) {
Go_blastASVs(project = project, asvsTable = raw_asv_file, blastDB = blast_db)
feature_file <- find_latest_final_asv(project)
} else {
feature_file <- raw_asv_file
input_gap_note <- "BLAST DB was not available locally, so the run used the current asvTable taxonomy columns instead of a new final_asvTable."
}
}
if (is.na(feature_file) || !file.exists(feature_file)) stop("No valid ASV input file was available for Go_tabTops().")
ps.csv <- Go_tabTops(csv = feature_file, project = project)
tree <- ape::read.tree(tree_file)
ps0 <- merge_phyloseq(ps.csv, sample_data(sampledata), phy_tree(tree))
############################################################
#=================      Filtering Run      =================#
############################################################
cutoff <- 7500
seq_from <- 397
seq_to <- 450
abundance_cutoff <- 0.00005
ps1.prune <- prune_samples(sample_sums(ps0) > cutoff, ps0)
p.rare <- Go_rare(ps1.prune, step = 1000, color = "GroupLabel", xlimit = 20000, label = NULL, se = FALSE) + ggplot2::theme(legend.position = "right")
rare_dir <- Go_path(project, pdf = "yes", table = "no", path = NULL)
ggplot2::ggsave(sprintf("%s/1_rarefaction.%s.%s.(Rarefaction).pdf", rare_dir$pdf, project, format(Sys.Date(), "%y%m%d")), plot = p.rare, device = "pdf", width = 8, height = 5, limitsize = FALSE)
Go_SeqLengths(ps1.prune)
ps1.size <- Go_SeqLengths(ps1.prune, from = seq_from, to = seq_to)
ps_filtered <- Go_filter(ps1.size, cutoff = abundance_cutoff)
meta0 <- data.frame(sample_data(ps_filtered), check.names = FALSE)
meta0$GroupLabel <- factor(as.character(meta0$GroupLabel), levels = group_orders)
meta0$Timepoint <- factor(as.character(meta0$Timepoint), levels = time_orders)
ps_use <- prune_samples(rownames(meta0), ps_filtered)
sample_data(ps_use) <- sample_data(meta0)
###########################################
#=========      Barchart         =========#
###########################################
for (tax_rank in barchart_tax_ranks) {
Go_barchart(psIN = ps_use, cate.vars = "GroupLabel", project = project, taxanames = tax_rank, orders = group_orders, simple = FALSE, mycols = plot.col, relative = TRUE, y_axis = NULL, x_label = NULL, facet = "Timepoint", legend = "bottom", cutoff = 0.01, name = ensure_report_token(tax_rank), ncol = NULL, mark = NULL, height = 5, width = 10)
}
barchart_tax_ranks <- c("Phylum", "Class","Order","Family", "Genus","Species")
group_orders
group_orders
###########################################
#=========    Alpha Diversity     =========#
###########################################
adiv_all <- Go_adiv(psIN = ps_use, project = project, alpha_metrics = alpha_metrics, name = ensure_report_token("AllSamples"))
Go_boxplot(df = adiv_all, cate.vars = "GroupLabel", project = project, outcomes = alpha_metrics, orders = group_orders, mycols = plot.col, combination = NULL, ylim = NULL, title = NULL, facet = "Timepoint", paired = NULL, name = ensure_report_token("GroupLabel"), ncol = NULL, addnumber = TRUE, statistics = TRUE, covariates = NULL, p_adjust = TRUE, cutoff = 0.1, min_height = 2, min_width = 2, plotCols = 2, plotRows = 1)
adiv_all$GroupLabel
unique(adiv_all$GroupLabel)
unique(adiv_all$Timepoint)
Go_boxplot(df = adiv_all, cate.vars = "GroupLabel", project = project, outcomes = alpha_metrics, orders = c(group_orders, "D+7",  "D+14"), mycols = plot.col, combination = NULL, ylim = NULL, title = NULL, facet = "Timepoint", paired = NULL, name = ensure_report_token("GroupLabel"), ncol = NULL, addnumber = TRUE, statistics = TRUE, covariates = NULL, p_adjust = TRUE, cutoff = 0.1, min_height = 2, min_width = 2, plotCols = 2, plotRows = 1)
###########################################
#=========     Beta Diversity     =========#
###########################################
Go_bdivPM(psIN = ps_use, cate.vars = "GroupLabel", project = project, orders = c(group_orders, "D+7",  "D+14"), distance_metrics = distance_metrics, cate.conf = NULL, plot = "PCoA", ellipse = TRUE, statistics = TRUE, mycols = plot.col, paired = NULL, combination = NULL, shapes = NULL, ID = NULL, facet = "Timepoint", name = ensure_report_token("GroupLabel"), addnumber = TRUE, height = 5, width = 10, plotCols = 3, plotRows = 1, strata_var = NULL, p_adjust = "BH")
############################################################
#=================      DA Analysis       =================#
############################################################
for (da_name in names(da_comparisons)) {
da_orders <- da_comparisons[[da_name]]
ps_da <- prune_samples(as.character(sample_data(ps_use)$GroupLabel) %in% da_orders, ps_use)
sample_data(ps_da)$PairLabel <- factor(as.character(sample_data(ps_da)$GroupLabel), levels = da_orders)
deseq_dir <- Go_Deseq2(psIN = ps_da, project = project, taxanames = NULL, cate.outs = "PairLabel", cate.conf = NULL, cont.conf = NULL, orders = da_orders, name = da_name)
Go_volcanoPlot(project = project, file_path = NULL, files = NULL, result = deseq_dir, fc = 0, mycols = da.col, name = da_name, overlaps = 10, font = 3, height = 5, width = 6)
aldex_dir <- Go_Aldex2(psIN = ps_da, project = project, cate.outs = "PairLabel", cont.outs = NULL, cate.conf = NULL, cont.conf = NULL, orders = da_orders, name = da_name)
Go_volcanoPlot(project = project, file_path = NULL, files = NULL, result = aldex_dir, fc = 0, mycols = da.col, name = da_name, overlaps = 10, font = 3, height = 5, width = 6)
ancom_dir <- Go_Ancom2(psIN = ps_da, project = project, data_type = "other", taxanames = NULL, cate.outs = "PairLabel", cate.conf = NULL, cont.conf = NULL, rand.eff = NULL, orders = da_orders, name = da_name)
Go_volcanoPlot(project = project, file_path = NULL, files = NULL, result = ancom_dir, fc = 0, mycols = da.col, name = da_name, overlaps = 10, font = 3, height = 5, width = 6)
}
############################################################
#=================      Report Objects      =================#
############################################################
dir_root <- sprintf("%s_%s", project, format(Sys.Date(), "%y%m%d"))
alpha_tab_file <- sprintf("%s/table/adiv/adiv.%s.%s.%s.csv", dir_root, project, ensure_report_token("AllSamples"), format(Sys.Date(), "%y%m%d"))
da_plot_dir <- file.path(dir_root, "pdf", "DA_plot")
da_labels <- extract_da_plot_labels(da_plot_dir)
sample_counts <- table(sampledata$GroupLabel)
sample_count_text <- paste(sprintf("%s=%s", names(sample_counts), as.integer(sample_counts)), collapse = "; ")
alpha_tab <- read.csv(alpha_tab_file, check.names = FALSE, stringsAsFactors = FALSE)
alpha_summary <- sprintf("Alpha-diversity table generated for %d filtered samples across %d requested metrics.", nrow(alpha_tab), length(alpha_metrics))
da_csv_files <- list.files(file.path(dir_root, "table"), pattern = "\\.csv$", full.names = TRUE, recursive = TRUE)
da_sig_text <- sprintf("Generated %d DA result tables across DESeq2, ALDEx2, and ANCOM2 subset comparisons.", length(da_csv_files))
expInfo <- Go_expInfo(Project_name = project, Samples_info = sprintf("%d study samples after metadata merge", nsamples(ps_use)), Sequencing_date = "03/24/2026", Sequencing_platform = "Illumina MiSeq", kit_number = expinfo_kit_number, pos_number = expinfo_pos_number, prep_number = expinfo_prep_number, spikein_number = expinfo_spikein_number, authorName1 = "Heekuk Park", authorName2 = "Dwayne Seeram")
dirInfo <- Go_dirInfo(Current_working_dir = currentwd, Image_locations = sprintf("%s/pdf/", dir_root), DA_image_location = sprintf("%s/pdf/DA_plot/", dir_root))
tabInfo <- Go_tabInfo(ASVs_Tab = feature_file, Tract_Tab = track_file, Alpha_divTab = alpha_tab_file, Alpha_div_LmerTab = NULL, PermanovaTab = NULL)
imgInfo <- Go_imgInfo(Rarefaction = "Rarefaction", Overview = NA, Barchart = barchart_tax_ranks, Bac.heatmap = "GroupLabel", Adivplot = c("GroupLabel"), Foreplot = NA, Bdivplot = c("GroupLabel"), DAplot = da_labels)
sumInfo <- Go_sumInfo(
Prep_overview = paste(na.omit(c(sprintf("Merged metadata into %d included study samples with labels: %s.", nrow(sampledata), sample_count_text), input_gap_note)), collapse = " "),
Taxa_overview = sprintf("Taxonomic composition outputs were generated at %s.", paste(barchart_tax_ranks, collapse = ", ")),
Alpha_div = alpha_summary,
Beta_div = sprintf("Beta-diversity PCoA outputs were generated with %s distances and Timepoint faceting.", paste(distance_metrics, collapse = ", ")),
Bacterial_div = "Heatmap and rank-specific relative-abundance barcharts were generated from the filtered phyloseq object.",
DA_test = da_sig_text,
Conclusion = "Main interpretation should focus on within-timepoint baseline-vs-post comparisons using the requested GroupLabel naming.",
Useful_info = "Controls and samples lacking recoverable metadata were retained in the mapping file but excluded from the main analysis."
)
############################################################
#=================        Render         =================#
############################################################
rmarkdown::render(input = rmd_template_path, output_format = "html_document", output_file = file.path(summary_report_dir, sprintf("%s_%s_Summary_report.html", format(Sys.Date(), "%Y%m%d"), project)), envir = environment())
png_count <- length(list.files(file.path(currentwd, dir_root, "pdf"), pattern = "\\.png$", recursive = TRUE))
if (png_count == 0) stop("HTML rendering did not generate any PNG assets. Stop and inspect the report contract before proceeding.")
# build package
setwd("~/Dropbox/04_Scripts/R_source/Gotools")
devtools::build() # generate Gotools_0.0.0.9000.tar.gz
# if added some function do document again (include namespace)
devtools::document()
