source_mapping_new <- "3_map/20260316_16S_GLP25.mapping.csv"
source_mapping_old <- "3_map/241021.fastq.mapping.csv"
mapping_file <- "3_map/20260324.fastq.mapping.GAB_labelmerge.csv"
raw_asv_file <- "1_out/fastq.260324.asvTable.csv"
track_file <- "1_out/fastq.260324.track.csv"
tree_file <- "1_out/fastq.260324.seqs.fna_tree/exported-tree/tree.nwk"
blast_db <- find_blast_db()
group_orders <- c("VB_D+7", "V_D+7", "GLPB_D+7", "GLP2_D+7", "VB_D+14", "V_D+14", "GLPB_D+14", "GLP2_D+14")
time_orders <- c("D+7", "D+14")
barchart_tax_ranks <- c("Phylum", "Class","Order","Family", "Genus","Species")
distance_metrics <- c("bray", "unifrac", "wunifrac")
alpha_metrics <- c("Chao1", "Shannon")
expinfo_kit_number <- 2
expinfo_pos_number <- 1
expinfo_prep_number <- 3
expinfo_spikein_number <- 2
setwd(currentwd)
if (!dir.exists(summary_report_dir)) dir.create(summary_report_dir, recursive = TRUE)
############################################################
#=================      Metadata Build      =================#
############################################################
mapping_full <- build_mapping_file(template_mapping_file, source_mapping_new, source_mapping_old, mapping_file)
sampledata <- subset(mapping_full, AnalysisUse == "Include")
rownames(sampledata) <- sampledata$SampleID
sampledata$GroupLabel <- factor(sampledata$GroupLabel, levels = group_orders)
sampledata$Timepoint <- factor(sampledata$Timepoint, levels = time_orders)
sampledata$TreatmentGroup <- factor(sampledata$TreatmentGroup, levels = c("Vehicle", "GLP-2"))
sampledata$TreatmentGroup2 <- factor(sampledata$TreatmentGroup2, levels = c("Baseline", "Sample"))
da_comparisons <- list(
Vehicle_D7 = c("VB_D+7", "V_D+7"),
Vehicle_D14 = c("VB_D+14", "V_D+14"),
GLP2_D7 = c("GLPB_D+7", "GLP2_D+7"),
