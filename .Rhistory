Go_boxplot(df = adiv_all, cate.vars = "GroupLabel", project = project, outcomes = alpha_metrics, orders = c(group_orders, "D+7",  "D+14"), mycols = alpha.col, combination = NULL, ylim = NULL, title = NULL, facet = "Timepoint", paired = NULL, name = ensure_report_token("GroupLabel"), ncol = NULL, addnumber = TRUE, statistics = TRUE, covariates = NULL, p_adjust = TRUE, cutoff = 0.1, min_height = 2, min_width = 2, plotCols = 2, plotRows = 1)
Gotool_dependency()
Go_blastASVs(project, asvsTable="1_out/fastq.260324.asvTable.csv", blastDB="/Users/heekukpark/DB/blastDB/16S_ribosomal_RNA")
ps.csv <- Go_tabTops(csv = "1_out/MAPS_Dav_BMT_16S_GAB_labelmerge.final_asvTable.260324.csv", project = project)
tree <- ape::read.tree(tree_file)
ps0 <- merge_phyloseq(ps.csv, sample_data(sampledata), phy_tree(tree))
############################################################
#=================      Filtering Run      =================#
############################################################
cutoff <- 7500
seq_from <- 397
seq_to <- 450
abundance_cutoff <- 0.00005
ps1.prune <- prune_samples(sample_sums(ps0) > cutoff, ps0)
p.rare <- Go_rare(ps1.prune, step = 1000, color = "GroupLabel", xlimit = 20000, label = NULL, se = FALSE) + ggplot2::theme(legend.position = "right")
rare_dir <- Go_path(project, pdf = "yes", table = "no", path = NULL)
ggplot2::ggsave(sprintf("%s/1_rarefaction.%s.%s.(Rarefaction).pdf", rare_dir$pdf, project, format(Sys.Date(), "%y%m%d")), plot = p.rare, device = "pdf", width = 8, height = 5, limitsize = FALSE)
Go_SeqLengths(ps1.prune)
ps1.size <- Go_SeqLengths(ps1.prune, from = seq_from, to = seq_to)
ps_filtered <- Go_filter(ps1.size, cutoff = abundance_cutoff)
meta0 <- data.frame(sample_data(ps_filtered), check.names = FALSE)
meta0$GroupLabel <- factor(as.character(meta0$GroupLabel), levels = group_orders)
meta0$Timepoint <- factor(as.character(meta0$Timepoint), levels = time_orders)
ps_use <- prune_samples(rownames(meta0), ps_filtered)
sample_data(ps_use) <- sample_data(meta0)
############################################################
#=================      Core Analysis      =================#
############################################################
barplot.col <- Go_myCols(custumCols = "cols3")
alpha.col   <- Go_myCols(piratepal = "basel")
bdiv.col    <- Go_myCols(piratepal = "basel")
da.col      <- c("#74ADD1", "#E31A1C")
###########################################
#=========      Barchart         =========#
###########################################
for (tax_rank in barchart_tax_ranks) {
Go_barchart(psIN = ps_use, cate.vars = "GroupLabel", project = project, taxanames = tax_rank, orders = c(group_orders, "D+7",  "D+14"), simple = FALSE, mycols = barplot.col, relative = TRUE, y_axis = NULL, x_label = NULL, facet = NULL, legend = "bottom", cutoff = 0.01, name = ensure_report_token(tax_rank), ncol = NULL, mark = NULL, height = 4, width = 8)
}
###########################################
#=========       Heatmap          =========#
###########################################
Go_pheatmap(psIN = ps_use, project = project, title = NULL, group1 = "GroupLabel", group2 = NULL, group3 = NULL, group4 = NULL, Ntax = 50, name = ensure_report_token("GroupLabel"), col_orders = group_orders, show_rownames = TRUE, show_colnames = FALSE, cutree_rows = NA, cutree_cols = NA, cluster_rows = TRUE, cluster_cols = TRUE, showPhylum = TRUE, width = 10)
###########################################
