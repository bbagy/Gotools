Go_bdivPM(psIN = ps2_sv, project = project, mycols = mycols, cate.vars = "sample_stage", orders = orders, distance_metrics = c("unifrac", "wunifrac", "bray"), plot = c("PCoA"), shapes = NULL, ID = NULL, ellipse = T, facet = NULL, name = "saliva", height = 4, width = 8, strata_var = "record_id", plotCols = 3)
Go_bdivPM(psIN = ps2_st, project = project, mycols = mycols, cate.vars = "sample_stage", orders = orders, distance_metrics = c("unifrac", "wunifrac", "bray"), plot = c("PCoA"), shapes = NULL, ID = NULL, ellipse = T, facet = NULL, name = "stool", height = 4, width = 8, strata_var = "record_id",plotCols = 3)
