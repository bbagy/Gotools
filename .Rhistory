ACC_merge = coalesce(as.character(ACCNO_TRAC), as.character(ACCNO), as.character(ACCNO_2)),
ACC_merge = normalize_acc(ACC_merge)
) %>%
select(
ACC_merge,
matches("(IMIPENEM|MEROPENEM|ERTAPENEM).+_sus", ignore.case = TRUE)
) %>%
distinct()
