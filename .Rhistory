Go_bdivPM(psIN = ps2_sv, project = project, mycols = mycols, cate.vars = "sample_stage", orders = orders, distance_metrics = c("unifrac", "wunifrac", "bray"), plot = c("PCoA"), shapes = NULL, ID = NULL, ellipse = T, facet = NULL, name = "saliva", height = 4, width = 5, strata_var = "record_id")
