build_mapping_file <- function(template_file, source_new_file, source_old_file, output_file) {
template_map <- read.csv(template_file, check.names = FALSE, stringsAsFactors = FALSE)
source_new <- read.csv(source_new_file, check.names = FALSE, stringsAsFactors = FALSE)
source_old <- read.csv(source_old_file, check.names = FALSE, stringsAsFactors = FALSE)
source_new$TreatmentGroup[source_new$TreatmentGroup == "Control"] <- "Vehicle"
source_new$TreatmentGroup2[source_new$TreatmentGroup2 == "Treatment"] <- "Sample"
source_new$Timepoint <- normalize_timepoint(source_new$Timepoint)
source_new$GroupLabel <- mapply(make_group_label, source_new$TreatmentGroup, source_new$TreatmentGroup2, source_new$Timepoint, USE.NAMES = FALSE)
source_new$Description <- source_new$GroupLabel
source_new$SourceMap <- basename(source_new_file)
source_new$Samples <- "Yes"
source_new$Sequencing_date <- "20260324"
source_new$SourceBatch <- "Batch_20260324"
source_new$AnalysisUse <- "Include"
keep_old <- source_old$SampleID %in% template_map$SampleID & nzchar(source_old$TreatmentGroup) & !(source_old$TreatmentGroup %in% c("Neg", "Pos"))
source_old_use <- source_old[keep_old, , drop = FALSE]
source_old_label <- source_old_use$TreatmentGroup
source_old_use$TreatmentGroup <- ifelse(grepl("^Vehicle", source_old_label), "Vehicle", "GLP-2")
source_old_use$TreatmentGroup2 <- ifelse(grepl("Baseline", source_old_label), "Baseline", "Sample")
source_old_use$Timepoint <- normalize_timepoint(source_old_use$Timepoint)
source_old_use$GroupLabel <- mapply(make_group_label, source_old_use$TreatmentGroup, source_old_use$TreatmentGroup2, source_old_use$Timepoint, USE.NAMES = FALSE)
source_old_use$Description <- source_old_use$GroupLabel
source_old_use$SourceMap <- basename(source_old_file)
source_old_use$SourceBatch <- "Batch_20241021"
source_old_use$AnalysisUse <- "Include"
controls_old <- source_old[source_old$SampleID %in% template_map$SampleID & source_old$TreatmentGroup %in% c("Neg", "Pos"), , drop = FALSE]
if (nrow(controls_old) > 0) {
controls_old$TreatmentGroup <- controls_old$TreatmentGroup
controls_old$TreatmentGroup2 <- ""
controls_old$Timepoint <- ""
controls_old$GroupLabel <- controls_old$TreatmentGroup
controls_old$Description <- controls_old$TreatmentGroup
controls_old$SourceMap <- basename(source_old_file)
controls_old$SourceBatch <- "Batch_20241021"
controls_old$AnalysisUse <- "Exclude_Control"
}
source_use <- rbind(
source_new[, c("SampleID", "Samples", "StudyID", "TreatmentGroup", "TreatmentGroup2", "Timepoint", "GroupLabel", "Description", "Sequencing_date", "SourceBatch", "SourceMap", "AnalysisUse")],
source_old_use[, c("SampleID", "Samples", "StudyID", "TreatmentGroup", "TreatmentGroup2", "Timepoint", "GroupLabel", "Description", "Sequencing_date", "SourceBatch", "SourceMap", "AnalysisUse")],
controls_old[, c("SampleID", "Samples", "StudyID", "TreatmentGroup", "TreatmentGroup2", "Timepoint", "GroupLabel", "Description", "Sequencing_date", "SourceBatch", "SourceMap", "AnalysisUse")]
)
source_use <- source_use[!duplicated(source_use$SampleID), , drop = FALSE]
merged_map <- merge(template_map["SampleID"], source_use, by = "SampleID", all.x = TRUE, sort = FALSE)
merged_map$Samples[is.na(merged_map$Samples)] <- "Yes"
merged_map$SourceMap[is.na(merged_map$SourceMap)] <- basename(source_old_file)
merged_map$SourceBatch[is.na(merged_map$SourceBatch)] <- "Unknown"
merged_map$AnalysisUse[is.na(merged_map$AnalysisUse)] <- "Exclude_MetadataMissing"
write.csv(merged_map, output_file, row.names = FALSE, quote = TRUE)
merged_map
}
