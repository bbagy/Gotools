basename(raw_asv_file),
basename(gab_mapping_file)
),
sprintf(
"A total of %s biological samples were retained after applying a %s-read cutoff, sequence-length filtering from %s to %s bp, and abundance filtering at %s.",
nsamples(ps_main),
cutoff,
seq_from,
seq_to,
abundance_cutoff
),
sprintf(
"Main comparison was limited to `%s` because the available metadata did not support timepoint, paired, or adjusted covariate analyses.",
comparison_var
)
),
Taxa_overview = "Taxonomic summaries were generated across Phylum to Species ranks for the retained MIRA and LUPUS samples.",
Alpha_div = "Alpha diversity was evaluated with Chao1 and Shannon metrics using nonparametric group comparison.",
Beta_div = "Beta diversity was evaluated with Bray, unweighted UniFrac, and weighted UniFrac PCoA panels.",
Bacterial_div = "Top taxa heatmap and rank-specific relative-abundance barcharts were generated from the filtered phyloseq object.",
DA_test = "Differential abundance testing used Deseq2, Aldex2, and ANCOM2, followed by volcano plot generation from the resulting DA tables.",
Summary = "This run is intentionally conservative and focuses on the biologically interpretable MIRA versus LUPUS contrast.",
Conclusion = "Interpretation should prioritize group-level contrasts and remain cautious because metadata depth is limited and external covariates are absent.",
Useful_info = "QC and control-like samples were retained in the metadata file for provenance but excluded from the main inferential analysis set."
)
