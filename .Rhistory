normalize_acc <- function(s){
s <- toupper(as.character(s))
gsub("[^A-Z0-9]", "", s)   # Ļ│Ąļ░▒/ĒĢśņØ┤Ēöł ļō▒ ņĀ£Ļ▒░
}
