setwd("~/Dropbox/04_scripts/R_source/R_storage/1_R_History/2026/20260306_NV_DEAPIM/")
input_file <- "Samplesheet_deapim.csv"   # 원본 파일 이름
output_file <- "Samplesheet_deapim_i5RC.csv"  # 변환 후 저장 파일 이름
# 파일 전체 읽기
lines <- readLines(input_file)
# [Data] 섹션의 시작과 끝 인덱스 찾기
start_idx <- grep("^\\[Data\\]", lines)
if (length(start_idx) == 0) stop("No [Data] section found in SampleSheet!")
# Data 섹션 이후 데이터프레임 읽기
header_line <- lines[start_idx + 1]
headers <- strsplit(header_line, ",|\t")[[1]]  # 쉼표나 탭 구분자 모두 대응
data_lines <- lines[(start_idx + 2):length(lines)]
data <- read.table(text = data_lines, sep = "\t", header = FALSE, fill = TRUE, quote = "", comment.char = "")
if (ncol(data) < length(headers)) {
data <- read.table(text = data_lines, sep = ",", header = FALSE, fill = TRUE, quote = "", comment.char = "")
}
colnames(data) <- headers
View(data)
# i5(index2) 변환
data$index3 <- as.character(reverseComplement(DNAStringSet(data$index2)))
View(data)
# i5(index2) 변환
data$index2 <- as.character(reverseComplement(DNAStringSet(data$index2)))
# (선택) I5_Index_ID도 함께 수정
data$I5_Index_ID <- paste0(data$I5_Index_ID, "_RC")
# 변환된 결과 합쳐서 다시 파일로 쓰기
output <- c(
lines[1:start_idx],          # Header, Reads, Settings 포함
paste(headers, collapse = ","),  # Data header
apply(data, 1, function(x) paste(x, collapse = ","))  # 변환된 Data
)
writeLines(output, output_file)
cat("✅ 변환 완료!\n새 파일:", output_file, "\n")
# build package
setwd("~/Dropbox/04_Scripts/R_source/Gotools")
devtools::build() # generate Gotools_0.0.0.9000.tar.gz
# if added some function do document again (include namespace)
devtools::document()
